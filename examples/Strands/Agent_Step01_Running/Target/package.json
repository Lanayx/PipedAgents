{
  "name": "fable-hello-world",
  "version": "1.0.0",
  "description": "A simple hello world Node.js console application built using F# Fable",
  "type": "module",
  "main": "dist/src/App.js",
  "scripts": {
    "build": "dotnet fable . --outDir dist --lang javascript --sourceMaps",
    "start": "npm run build && node --env-file=.env dist/src/App.js"
  },
