{
  "compilerOptions": {
    // Target JavaScript version
    "target": "ES2020",
    
    // Module system
    "module": "CommonJS",
    "moduleResolution": "node",
    
    // Type checking options
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    
    // Node.js specific settings
    "types": ["node"],
    "lib": ["ES2020"],
    
    // Skip type checking of declaration files
    "skipLibCheck": true,
    
    // Allow importing .ts extensions (needed for Fable output)
    "allowImportingTsExtensions": true,
    "noEmit": true,
    
    // ts-node specific options
    "allowJs": true,
    "resolveJsonModule": true,
    
    // Experimental decorators (if needed for Fable)
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  
  // ts-node configuration
  "ts-node": {
    "esm": false,
    "experimentalSpecifierResolution": "node"
  },
  
  // Include TypeScript files generated by Fable
  "include": [
    "dist/**/*.ts"
  ],
  
  // Exclude node_modules and other unnecessary files
  "exclude": [
    "node_modules",
    "src/**/*"
  ]
}